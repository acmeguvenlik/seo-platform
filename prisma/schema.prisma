// Prisma Schema for SEO Tools Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  role          Role     @default(USER)
  plan          Plan     @default(FREE)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  toolUsages      ToolUsage[]
  savedAnalyses   SavedAnalysis[]
  apiKeys         ApiKey[]
  sessions        Session[]
  blogPosts       BlogPost[]
  uploadedImages  Image[]

  @@index([email])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model ToolUsage {
  id           String   @id @default(cuid())
  userId       String?
  toolSlug     String
  inputHash    String
  result       Json
  processingMs Int
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([toolSlug])
  @@index([createdAt])
  @@index([inputHash])
}

model SavedAnalysis {
  id         String   @id @default(cuid())
  userId     String
  name       String
  toolSlug   String
  inputData  Json
  resultData Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([toolSlug])
  @@index([createdAt])
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique
  lastUsedAt  DateTime?
  usageCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}

// Blog System Models

enum Locale {
  en
  tr
  de
  es
  fr
}

enum PublicationStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum ImageFormat {
  JPEG
  PNG
  WEBP
}

model BlogPost {
  id              String            @id @default(cuid())
  title           String
  content         String            @db.Text
  excerpt         String?           @db.Text
  slug            String
  locale          Locale
  status          PublicationStatus @default(DRAFT)
  
  // SEO
  seoTitle        String?
  seoDescription  String?
  ogImage         String?
  canonicalUrl    String?
  
  // Relationships
  categoryId      String?
  category        Category?         @relation(fields: [categoryId], references: [id])
  tags            BlogPostTag[]
  featuredImageId String?
  featuredImage   Image?            @relation(fields: [featuredImageId], references: [id])
  
  // Translation linking
  translationOfId String?
  translationOf   BlogPost?         @relation("Translations", fields: [translationOfId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  translations    BlogPost[]        @relation("Translations")
  
  // Metadata
  authorId        String
  author          User              @relation(fields: [authorId], references: [id])
  readingTime     Int
  viewCount       Int               @default(0)
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  publishedAt     DateTime?
  
  // Analytics
  views           PostView[]
  
  @@unique([slug, locale])
  @@index([locale])
  @@index([status])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([viewCount])
  @@index([locale, status, publishedAt])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String
  description String?    @db.Text
  locale      Locale
  posts       BlogPost[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@unique([slug, locale])
  @@index([locale])
}

model Tag {
  id        String        @id @default(cuid())
  name      String
  slug      String
  locale    Locale
  posts     BlogPostTag[]
  
  createdAt DateTime      @default(now())
  
  @@unique([slug, locale])
  @@index([locale])
}

model BlogPostTag {
  postId String
  tagId  String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([postId, tagId])
  @@index([tagId])
}

model Image {
  id          String      @id @default(cuid())
  filename    String
  altText     String
  url         String
  width       Int
  height      Int
  format      ImageFormat
  size        Int
  
  // Variants
  thumbnailUrl String
  mediumUrl    String
  largeUrl     String
  ogImageUrl   String
  
  // Metadata
  uploadedBy  String
  uploader    User       @relation(fields: [uploadedBy], references: [id])
  uploadedAt  DateTime   @default(now())
  
  // Usage
  posts       BlogPost[]
  
  @@index([uploadedBy])
  @@index([uploadedAt])
}

model PostView {
  id            String   @id @default(cuid())
  postId        String
  post          BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  sessionId     String
  
  // Metadata
  referrer      String?
  userAgent     String
  locale        Locale
  timeOnPage    Int?
  
  // Timestamps
  viewedAt      DateTime @default(now())
  
  @@unique([postId, sessionId])
  @@index([postId, viewedAt])
  @@index([sessionId])
}
